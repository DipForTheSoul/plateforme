# ForTheSoul — variables d'environnement
# Copier ce fichier en `.env.local` et remplir les vraies valeurs.
# RÈGLE D'OR n°4 : jamais de clé dans le code ni dans un commit.

# --- Supabase (Rodrigue : projet Supabase du client, Settings → API) ---
NEXT_PUBLIC_SUPABASE_URL=https://VOTRE-PROJET.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=PLACEHOLDER_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=PLACEHOLDER_SERVICE_ROLE_KEY

# --- Stripe (mode test d'abord : Dashboard → Developers → API keys) ---
STRIPE_SECRET_KEY=sk_test_PLACEHOLDER
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_PLACEHOLDER
# Webhook : `stripe listen --forward-to localhost:3000/api/stripe/webhook`
# ou Dashboard → Webhooks → endpoint https://forthesoul.ch/api/stripe/webhook
STRIPE_WEBHOOK_SECRET=whsec_PLACEHOLDER

# --- Resend (plan gratuit : 3000 e-mails/mois — vide = logs console) ---
RESEND_API_KEY=
EMAIL_FROM="ForTheSoul <welcome@forthesoul.ch>"

# --- Site ---
NEXT_PUBLIC_SITE_URL=https://forthesoul.ch

# --- Géocodage : Nominatim/OpenStreetMap, gratuit, AUCUNE clé nécessaire. ---
